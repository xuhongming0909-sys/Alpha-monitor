# Server
PORT=5000
HOST=0.0.0.0
SERVER_BASE_URL=http://127.0.0.1:5000

# Data profile
# shared: all branches share market databases and runtime JSON files
# any other value: use branch-local runtime data under data/profiles/<profile>
ALPHA_DB_PROFILE=shared
# Optional explicit shared data directory override
# ALPHA_SHARED_DATA_DIR=./data/shared

# Python runtime (optional override)
# PYTHON_BIN=python3

# Jisilu cookie for full convertible bond market data
# JISILU_COOKIE=

# No mock market events: runtime should use real upstream data only
