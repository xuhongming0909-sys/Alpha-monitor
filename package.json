{
  "name": "alpha-monitor-refactor",
  "version": "1.0.0",
  "private": true,
  "description": "Refactored Alpha Monitor with cleaner architecture and improved UI",
  "scripts": {
    "dev": "node start_server.js",
    "start": "node start_server.js",
    "check:health": "powershell -ExecutionPolicy Bypass -File ./tools/check_health.ps1",
    "deploy:server:auto": "DEPLOY_MODE=auto bash ./tools/deploy/update_from_github.sh",
    "deploy:server:full": "bash ./tools/deploy/update_from_github.sh",
    "deploy:server:fast": "bash ./tools/deploy/update_fast.sh",
    "check": "node smoke_check.js",
    "check:constitution": "python tools/check_constitution_sync.py",
    "check:boundaries": "python tools/check_plugin_boundaries.py",
    "agent:mini:task": "python tools/render_mini_swe_task.py",
    "sync:server:env": "python tools/deploy/sync_remote_env_from_profile.py",
    "sync:pairs": "python tools/export_pair_pool.py --refresh",
    "sync:subscriptions": "python data_dispatch.py ipo && python data_dispatch.py bonds",
    "sync:cb-stock-history": "python data_dispatch.py sync-cb-stock-history",
    "sync:cb-stock-history:full": "python data_dispatch.py sync-cb-stock-history --force-full",
    "sync:premium:update": "python tools/rebuild_premium_db.py --mode update",
    "sync:premium:missing": "python tools/rebuild_premium_db.py --mode update --only-missing",
    "sync:premium:rebuild": "python tools/rebuild_premium_db.py --mode rebuild"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "yaml": "^2.8.2"
  }
}


