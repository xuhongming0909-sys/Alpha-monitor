{
  "name": "alpha-monitor-refactor",
  "version": "1.0.0",
  "private": true,
  "description": "Refactored Alpha Monitor with cleaner architecture and improved UI",
  "scripts": {
    "dev": "node start_server.js",
    "start": "node start_server.js",
    "check:health": "powershell -ExecutionPolicy Bypass -File ./scripts/check_health.ps1",
    "deploy:server:auto": "DEPLOY_MODE=auto bash ./deploy/update_from_github.sh",
    "deploy:server:full": "bash ./deploy/update_from_github.sh",
    "deploy:server:fast": "bash ./deploy/update_fast.sh",
    "ui:build": "cd ui && npm run build",
    "ui:check": "cd ui && npm run check",
    "check": "node tests/smoke_check.js",
    "check:boundaries": "python3 scripts/check_plugin_boundaries.py",
    "agent:mini:task": "python3 scripts/render_mini_swe_task.py",
    "sync:server:env": "python3 deploy/sync_remote_env_from_profile.py",
    "sync:pairs": "python3 scripts/export_pair_pool.py --refresh",
    "sync:subscriptions": "python3 data_dispatch.py ipo && python3 data_dispatch.py bonds",
    "sync:cb-stock-history": "python3 data_dispatch.py sync-cb-stock-history",
    "sync:cb-stock-history:full": "python3 data_dispatch.py sync-cb-stock-history --force-full",
    "sync:premium:update": "python3 scripts/rebuild_premium_db.py --mode update",
    "sync:premium:missing": "python3 scripts/rebuild_premium_db.py --mode update --only-missing",
    "sync:premium:rebuild": "python3 scripts/rebuild_premium_db.py --mode rebuild"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
